// Prisma schema — replace this with your actual data models for the hackathon
// Run: npx prisma migrate dev --name init   (after filling in DATABASE_URL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Example models — delete and replace with your own ───────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}
