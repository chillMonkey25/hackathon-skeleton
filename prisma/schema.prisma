// Prisma schema — add your models here once the hackathon prompt is known.
// One person writes the full schema, runs the migration, then everyone branches.
//
// Rules:
//   - Every model: id String @id @default(cuid())
//   - Every model: createdAt DateTime @default(now())
//   - Each group owns their own models — no group queries another group's tables
//   - Run: npx prisma migrate dev --name <description>  after any change
//   - Run: npx prisma generate  after any change

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Add your models here
